{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Electron Forge: Launch",
      "type": "node",
      "request": "launch",
      "cwd": "${workspaceFolder}",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev:debug", "--", "--", "--remote-debugging-port=9222"],
      "skipFiles": ["<node_internals>/**"],
      "console": "integratedTerminal",
      "autoAttachChildProcesses": true,
      "sourceMaps": true,
      "resolveSourceMapLocations": [
        "${workspaceFolder}/**",
        "!**/node_modules/**"
      ]
    },
    {
      "name": "Attach to Main Process",
      "type": "node",
      "request": "attach",
      "port": 9229,
      "cwd": "${workspaceFolder}",
      "sourceMaps": true,
      "restart": true,
      "skipFiles": ["<node_internals>/**"],
      "resolveSourceMapLocations": [
        "${workspaceFolder}/**",
        "!**/node_modules/**"
      ]
    },
    {
      "name": "Attach to Renderer",
      "type": "chrome",
      "request": "attach",
      "port": 9222,
      "webRoot": "${workspaceFolder}/src",
      "timeout": 60000,
      "urlFilter": "http://localhost:5173/*",
      "sourceMaps": true,
      "sourceMapPathOverrides": {
        "webpack:///./src/*": "${webRoot}/*",
        "vite:///*": "${workspaceFolder}/*",
        "/__parcel_source_root/*": "${workspaceFolder}/*"
      },
      "skipFiles": [
        "<node_internals>/**",
        "**/node_modules/**"
      ]
    }
  ],
  "compounds": [
    {
      "name": "Debug All (Main + Renderer)",
      "configurations": ["Attach to Main Process", "Attach to Renderer"],
      "stopAll": true,
      "presentation": {
        "order": 1
      }
    }
  ]
}
